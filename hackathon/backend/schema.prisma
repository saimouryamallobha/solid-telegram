generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id       String @id @default(uuid())
  email    String @unique
  password String
  role     String @default("MANAGER") // MANAGER, DRIVER, SAFETY, FINANCE
  name     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Vehicle {
  id              String   @id @default(uuid())
  regNumber       String   @unique
  name            String
  model           String
  type            String
  maxLoadCapacity Float
  odometer        Float
  acquisitionCost Float
  status          String   @default("AVAILABLE") // AVAILABLE, ON_TRIP, IN_SHOP, RETIRED
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  trips           Trip[]
  maintenanceLogs MaintenanceLog[]
  fuelExpenses    FuelExpense[]
  documents       Document[]
}

model Driver {
  id                String   @id @default(uuid())
  name              String
  licenseNumber     String   @unique
  licenseCategory   String
  licenseExpiryDate DateTime
  contactNumber     String
  safetyScore       Float    @default(100.0)
  status            String   @default("AVAILABLE") // AVAILABLE, ON_TRIP, OFF_DUTY, SUSPENDED
  salary            Float    @default(0.0)
  joinDate          DateTime @default(now())
  rating            Float    @default(5.0) // 1-5 passenger rating
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  trips             Trip[]
  documents         Document[]
  attendances       Attendance[]
  fines             Fine[]
}

model Trip {
  id            String   @id @default(uuid())
  source        String
  destination   String
  cargoWeight   Float
  distance      Float
  status        String   @default("DRAFT") // DRAFT, DISPATCHED, COMPLETED, CANCELLED
  vehicleId     String
  driverId      String
  startTime     DateTime?
  endTime       DateTime?
  fuelConsumed  Float?
  startOdometer Float?
  endOdometer   Float?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  vehicle Vehicle @relation(fields: [vehicleId], references: [id])
  driver  Driver  @relation(fields: [driverId], references: [id])
  fuelExpenses FuelExpense[]
}

model MaintenanceLog {
  id        String   @id @default(uuid())
  vehicleId String
  type      String   // e.g., Oil Change, Tire Replacement
  cost      Float
  date      DateTime @default(now())
  status    String   @default("OPEN") // OPEN, CLOSED
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vehicle Vehicle @relation(fields: [vehicleId], references: [id])
}

model FuelExpense {
  id        String   @id @default(uuid())
  vehicleId String
  tripId    String?
  liters    Float
  cost      Float
  date      DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vehicle Vehicle @relation(fields: [vehicleId], references: [id])
  trip    Trip?   @relation(fields: [tripId], references: [id])
}

model Document {
  id         String   @id @default(uuid())
  type       String   // LICENSE, REGISTRATION, INSURANCE, PERMIT
  name       String
  expiryDate DateTime
  driverId   String?
  vehicleId  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  driver  Driver?  @relation(fields: [driverId], references: [id])
  vehicle Vehicle? @relation(fields: [vehicleId], references: [id])
}

model Attendance {
  id          String   @id @default(uuid())
  driverId    String
  date        DateTime @default(now())
  status      String   @default("PRESENT") // PRESENT, ABSENT, LEAVE
  hoursWorked Float    @default(0.0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  driver Driver @relation(fields: [driverId], references: [id])
}

model Fine {
  id       String   @id @default(uuid())
  driverId String
  reason   String   // OVERWORKING, DUPLICATE_TRIP, OVERSPEEDING
  amount   Float
  date     DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  driver Driver @relation(fields: [driverId], references: [id])
}
